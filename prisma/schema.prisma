generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

enum Industry {
  roofing
  hvac
  plumbing
  landscaping
}

enum UserRole {
  owner
  admin
  manager
  sales
  technician
  support
  accountant
}

enum LeadStatus {
  new
  contacted
  qualified
  proposal
  won
  lost
}

enum JobStatus {
  scheduled
  in_progress
  completed
  cancelled
}

enum QuoteStatus {
  draft
  sent
  approved
  rejected
  expired
}

enum SubscriptionStatus {
  active
  trial
  cancelled
  expired
}

enum MessageChannel {
  sms
  email
  whatsapp
  internal
}

model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique

  industry  Industry?

  plan      String   @default("starter")

  logo      String?

  phone     String?
  email     String?

  address   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users           User[]
  leads           Lead[]
  customers       Customer[]
  pipelines       Pipeline[]
  deals           Deal[]
  quotes          Quote[]
  jobs            Job[]
  events          Event[]
  conversations   Conversation[]
  automations     Automation[]
  subscriptions   Subscription[]
  invoices        Invoice[]
  aiLogs          AiLog[]
  settings        OrganizationSettings?
  platformLogs    PlatformLog[]
}

model User {
  id           String   @id @default(uuid())

  orgId        String
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  name         String
  email        String   @unique

  passwordHash String

  role         UserRole

  avatar       String?

  status       String @default("active")

  createdAt    DateTime @default(now())

  assignedLeads Lead[]
  deals        Deal[]
  jobs         Job[]
  events       Event[]
  messages     Message[]
  aiLogs       AiLog[]
  sessions     Session[]
}

model Session {
  id         String @id @default(uuid())

  userId     String
  user       User @relation(fields: [userId], references: [id], onDelete: Cascade)

  token      String @unique

  expiresAt  DateTime

  createdAt  DateTime @default(now())
}

model Lead {
  id          String @id @default(uuid())

  orgId       String
  organization Organization @relation(fields:[orgId], references:[id], onDelete: Cascade)

  source      String?

  firstName   String
  lastName    String?

  phone       String?
  email       String?

  address     String?

  industry    Industry?

  status      LeadStatus @default(new)

  assignedTo  String?
  assignee    User? @relation(fields:[assignedTo], references:[id])

  notes       String?

  createdAt   DateTime @default(now())

  customer Customer?
}

model Customer {
  id           String @id @default(uuid())

  orgId        String
  organization Organization @relation(fields:[orgId], references:[id], onDelete: Cascade)

  leadId       String? @unique
  lead         Lead? @relation(fields:[leadId], references:[id])

  companyName  String?

  firstName    String
  lastName     String?

  email        String?
  phone        String?

  address      String?
  city         String?
  state        String?
  zip          String?

  notes        String?

  createdAt    DateTime @default(now())

  deals        Deal[]
  quotes       Quote[]
  jobs         Job[]
  conversations Conversation[]
  invoices     Invoice[]

  hvacUnits        HvacUnit[]
  plumbingAssets   PlumbingAsset[]
}

model Pipeline {
  id         String @id @default(uuid())

  orgId      String
  organization Organization @relation(fields:[orgId], references:[id])

  name       String

  stages     PipelineStage[]
}

model PipelineStage {
  id          String @id @default(uuid())

  pipelineId  String
  pipeline    Pipeline @relation(fields:[pipelineId], references:[id], onDelete: Cascade)

  name        String

  position    Int

  deals       Deal[]
}

model Deal {
  id          String @id @default(uuid())

  orgId       String
  organization Organization @relation(fields:[orgId], references:[id])

  customerId  String
  customer    Customer @relation(fields:[customerId], references:[id])

  stageId     String
  stage       PipelineStage @relation(fields:[stageId], references:[id])

  title       String

  value       Decimal @db.Decimal(12,2)

  probability Int?

  assignedTo  String?
  assignee    User? @relation(fields:[assignedTo], references:[id])

  expectedClose DateTime?
}

model Quote {
  id           String @id @default(uuid())

  orgId        String
  organization Organization @relation(fields:[orgId], references:[id])

  customerId   String
  customer     Customer @relation(fields:[customerId], references:[id])

  quoteNumber  String @unique

  subtotal     Decimal @db.Decimal(12,2)

  tax          Decimal @db.Decimal(12,2)

  total        Decimal @db.Decimal(12,2)

  status       QuoteStatus @default(draft)

  validUntil   DateTime?

  createdAt    DateTime @default(now())

  items        QuoteItem[]
  jobs         Job[]
}

model QuoteItem {
  id         String @id @default(uuid())

  quoteId    String
  quote      Quote @relation(fields:[quoteId], references:[id], onDelete: Cascade)

  itemName   String

  qty        Int

  price      Decimal @db.Decimal(12,2)

  total      Decimal @db.Decimal(12,2)
}

model Job {
  id             String @id @default(uuid())

  orgId          String
  organization   Organization @relation(fields:[orgId], references:[id])

  customerId     String
  customer       Customer @relation(fields:[customerId], references:[id])

  quoteId        String?
  quote          Quote? @relation(fields:[quoteId], references:[id])

  title          String

  status         JobStatus @default(scheduled)

  technicianId   String?
  technician     User? @relation(fields:[technicianId], references:[id])

  scheduledDate  DateTime?

  completedDate  DateTime?

  notes          String?

  events         Event[]

  roofingProject RoofingProject?
  landscapingProject LandscapingProject?
}

model Event {
  id          String @id @default(uuid())

  orgId       String
  organization Organization @relation(fields:[orgId], references:[id])

  title       String

  startTime   DateTime

  endTime     DateTime

  userId      String?
  user        User? @relation(fields:[userId], references:[id])

  jobId       String?
  job         Job? @relation(fields:[jobId], references:[id])
}

model Conversation {
  id          String @id @default(uuid())

  orgId       String
  organization Organization @relation(fields:[orgId], references:[id])

  customerId  String
  customer    Customer @relation(fields:[customerId], references:[id])

  channel     MessageChannel

  createdAt   DateTime @default(now())

  messages    Message[]
}

model Message {
  id             String @id @default(uuid())

  conversationId String
  conversation   Conversation @relation(fields:[conversationId], references:[id], onDelete: Cascade)

  senderId       String?
  sender         User? @relation(fields:[senderId], references:[id])

  body           String

  createdAt      DateTime @default(now())
}

model Automation {
  id            String @id @default(uuid())

  orgId         String
  organization  Organization @relation(fields:[orgId], references:[id])

  name          String

  triggerEvent  String

  active        Boolean @default(true)

  steps         AutomationStep[]
}

model AutomationStep {
  id            String @id @default(uuid())

  automationId  String
  automation    Automation @relation(fields:[automationId], references:[id], onDelete: Cascade)

  actionType    String

  config        Json

  position      Int
}

model Subscription {
  id            String @id @default(uuid())

  orgId         String
  organization  Organization @relation(fields:[orgId], references:[id])

  provider      String

  externalId    String?

  plan          String

  status        SubscriptionStatus

  renewAt       DateTime?
}

model Invoice {
  id            String @id @default(uuid())

  orgId         String
  organization  Organization @relation(fields:[orgId], references:[id])

  customerId    String
  customer      Customer @relation(fields:[customerId], references:[id])

  amount        Decimal @db.Decimal(12,2)

  status        String

  dueDate       DateTime?
}

model AiLog {
  id            String @id @default(uuid())

  orgId         String
  organization  Organization @relation(fields:[orgId], references:[id])

  userId        String
  user          User @relation(fields:[userId], references:[id])

  prompt        String

  response      String

  tokens        Int?

  createdAt     DateTime @default(now())
}

model OrganizationSettings {
  id            String @id @default(uuid())

  orgId         String @unique
  organization  Organization @relation(fields:[orgId], references:[id])

  timezone      String?

  currency      String?

  branding      Json?

  integrations  Json?
}

model AdminUser {
  id            String @id @default(uuid())

  email         String @unique

  passwordHash  String

  role          String
}

model PlatformLog {
  id            String @id @default(uuid())

  orgId         String
  organization  Organization @relation(fields:[orgId], references:[id])

  eventType     String

  payload       Json

  createdAt     DateTime @default(now())
}

model RoofingProject {
  id              String @id @default(uuid())

  jobId           String @unique
  job             Job @relation(fields:[jobId], references:[id])

  roofType        String?

  material        String?

  areaSqft        Decimal? @db.Decimal(10,2)

  insuranceClaim  Boolean @default(false)
}

model HvacUnit {
  id            String @id @default(uuid())

  customerId    String
  customer      Customer @relation(fields:[customerId], references:[id])

  model         String?

  serialNo      String?

  installDate   DateTime?
}

model PlumbingAsset {
  id            String @id @default(uuid())

  customerId    String
  customer      Customer @relation(fields:[customerId], references:[id])

  fixtureType   String?

  location      String?
}

model LandscapingProject {
  id            String @id @default(uuid())

  jobId         String @unique
  job           Job @relation(fields:[jobId], references:[id])

  yardArea      Decimal? @db.Decimal(10,2)

  irrigation    Boolean @default(false)
}