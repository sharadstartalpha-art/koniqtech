generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

model User {
  id                 String               @id @default(cuid())
  email              String               @unique
  password           String
  name               String?
  role               Role                 @default(USER)
  createdAt          DateTime             @default(now())
  resetTokens        PasswordResetToken[]
  verificationTokens VerificationToken[]
  // ✅ COMPANY RELATION (FIXED)
  companyId          String?
  company            Company?             @relation("CompanyUsers", fields: [companyId], references: [id])
credits  Int    @default(0)
  // ✅ OWNER RELATION
  ownedCompany  Company?       @relation("CompanyOwner")
  subscriptions Subscription[]
  projects      Project[]
  leads         Lead[]
  balance       Balance?
  transactions  Transaction[]
  payments      Payment[]
  unsubscribed  Boolean        @default(false)
  dailyLimit    Int            @default(20)
}

model Company {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  // 👑 OWNER
  ownerId String @unique
  owner   User   @relation("CompanyOwner", fields: [ownerId], references: [id])

  // 👥 USERS
  users User[] @relation("CompanyUsers")
}

model Product {
  id          String  @id @default(cuid())
  name        String // "Lead Finder"
  slug        String  @unique // "lead-finder"
  description String?
  price       Int // credits cost OR subscription price
  active      Boolean @default(true)

  createdAt DateTime @default(now())

  projects Project[]
}

model Project {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  chats     Chat[]
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])

  leads Lead[]
}

model Lead {
  id           String         @id @default(cuid())
  name         String?
  email        String?
  company      String?
  website      String?
  phone        String? // ✅ ADD
  location     String? // ✅ ADD
  source       String? // ✅ ADD THIS
  contactEmail String?
  userId       String
  projectId    String
  sequences    LeadSequence[]
  createdAt    DateTime       @default(now())

  user       User        @relation(fields: [userId], references: [id])
  project    Project     @relation(fields: [projectId], references: [id])
  LeadStatus LeadStatus?
}

model Balance {
  id     String @id @default(cuid())
  amount Int    @default(10)

  userId String @unique
  user   User   @relation(fields: [userId], references: [id])
}

model Transaction {
  id        String   @id @default(cuid())
  amount    Int
  type      String
  status    String?
  provider  String? // ✅ ADD THIS
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
}

model Chat {
  id        String  @id @default(cuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id])

  messages Message[]

  createdAt DateTime @default(now())
}

model Message {
  id     String @id @default(cuid())
  chatId String
  chat   Chat   @relation(fields: [chatId], references: [id])

  role    String
  content String

  createdAt DateTime @default(now())
}

model PasswordResetToken {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model VerificationToken {
  id String @id @default(cuid())

  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  email     String
  token     String
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model LeadSequence {
  id          String   @id @default(cuid())
  leadId      String
  subject     String
  content     String
  scheduledAt DateTime
  sent        Boolean  @default(false)

  lead Lead @relation(fields: [leadId], references: [id])
}

model LeadStatus {
  id     String @id @default(cuid())
  leadId String @unique
  status String

  lead Lead @relation(fields: [leadId], references: [id])
}

model Plan {
  id          String   @id @default(cuid())
  name        String
  price       Int
  credits     Int
  description String?
  createdAt   DateTime @default(now())

  subscriptions Subscription[]
}

model Subscription {
  id        String   @id @default(cuid())
  userId    String   @unique // 🔥 THIS IS REQUIRED
  planId    String
  status    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
  plan Plan @relation(fields: [planId], references: [id])

  @@unique([userId, planId])
}

model Payment {
  id        String   @id @default(cuid())
  userId    String
  amount    Float
  status    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model Campaign {
  id        String   @id @default(cuid())
  name      String
  userId    String
  createdAt DateTime @default(now())

  steps CampaignStep[]
}

model CampaignStep {
  id         String @id @default(cuid())
  campaignId String
  subject    String
  content    String
  delay      Int // hours

  campaign Campaign @relation(fields: [campaignId], references: [id])
}

model EmailLog {
  id          String    @id @default(cuid())
  userId      String
  leadId      String?
  email       String
  scheduledAt DateTime?
  status      String
  opened      Boolean   @default(false)
  clicked     Boolean   @default(false)

  createdAt DateTime @default(now())
}



model Email {
  id        String   @id @default(cuid())
  threadId  String
  from      String
  to        String
  body      String
  opened    Boolean  @default(false)
  createdAt DateTime @default(now())

  thread EmailThread @relation(fields: [threadId], references: [id])
}

model EmailThread {
  id        String   @id @default(cuid())
  userId    String
  subject   String
  createdAt DateTime @default(now())

  // ✅ REQUIRED (this was missing)
  messages EmailMessage[]
  Email    Email[]
}

model EmailMessage {
  id        String   @id @default(cuid())
  threadId  String
  from      String
  to        String
  body      String
  createdAt DateTime @default(now())

  // ✅ RELATION (correct)
  thread EmailThread @relation(fields: [threadId], references: [id])
}

model EmailQueue {
  id      String @id @default(cuid())
  userId  String
  email   String
  subject String
  body    String

  status   String @default("PENDING")
  attempts Int    @default(0)

  scheduledAt DateTime
  createdAt   DateTime @default(now())
  stopped     Boolean  @default(false)
}

