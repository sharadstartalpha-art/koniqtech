generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}





model Payment {
  id        String   @id @default(uuid())
  userId    String
  productId String
  amount    Float
  status    String
  createdAt DateTime @default(now())
}

model MagicLink {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Product {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())

  plans         Plan[]
  invoices      Invoice[]
  subscriptions Subscription[]
}

model Plan {
  id            String         @id @default(uuid())
  productId     String
  name          String // Free / Pro / Business
  price         Float
  invoiceLimit  Int?
  paypalPlanId String? @unique
  createdAt     DateTime       @default(now())
  active        Boolean        @default(true)
  product       Product        @relation(fields: [productId], references: [id])
  subscriptions Subscription[]
}

model Subscription {
  id                   String    @id @default(uuid())
  userId               String
  productId            String
  planId               String // 🔥 NEW
  paypalSubscriptionId String?
  status               String
  createdAt            DateTime  @default(now())
  expiresAt            DateTime? // ✅ ADD THIS
  currentPeriodEnd DateTime?   // ✅ ADD THIS
  product              Product   @relation(fields: [productId], references: [id])
  plan                 Plan      @relation(fields: [planId], references: [id])
  user                 User      @relation(fields: [userId], references: [id])
}



model PaymentLink {
  id        String   @id @default(uuid())
  userId    String
  title     String
  url       String?   // 👈 TEMP OPTIONAL
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}



enum ReminderMode {
  manual
  auto
}

enum ReminderType {
  friendly
  firm
  final
}


model ReminderTemplate {
  id        String   @id @default(cuid())
  userId    String

  name      String   // "Friendly" | "Firm" | "Final"
  subject   String
  html      String   // full email HTML

  type      String   // 🔥 "friendly" | "firm" | "final" | "custom"
  isDefault Boolean  @default(false)

  
  createdAt DateTime @default(now())
  reminderSchedules  ReminderSchedule[]
}


model Reminder {
  id        String @id @default(uuid())

  userId    String
  invoiceId String

  invoice   Invoice @relation(fields: [invoiceId], references: [id])

  type   ReminderType
  status String
  mode   ReminderMode

  email  String
  amount Float

  html String
  text String

  templateId String?
  scheduleId String?

  sentAt    DateTime @default(now())
  createdAt DateTime @default(now())

  opens   Int     @default(0)
  clicked Boolean @default(false)
}


model Invoice {
  id            String      @id @default(uuid())

  userId        String
  productId     String

  clientEmail   String
  clientName    String?

  // Financials

  amount        Float

  paidAmount    Float       @default(0)

  balanceAmount Float?

  currency      String      @default("USD")

  // Status

  status        String      @default("unpaid")

  mode          String      @default("manual")

  // Dates

  dueDate       DateTime

  paidAt        DateTime?

  createdAt     DateTime    @default(now())

  updatedAt     DateTime    @updatedAt

  // Payment

  paymentLink   String?

  transactionId String?

  paymentMethod String?

  // Automation

  autoReminder  Boolean     @default(true)

  // Relations

  product       Product     @relation(fields: [productId], references: [id])

  user          User        @relation(fields: [userId], references: [id])

  reminders     Reminder[]
  reminderSchedules  ReminderSchedule[]
}


model User {
  id          String   @id @default(uuid())

  email       String   @unique
  password    String?

  name        String?
  avatar      String?

  role        String   @default("USER")

  isVerified  Boolean  @default(false)

  otp         String?
  otpExpiry   DateTime?

  verifyToken String?
  verifyExpiry DateTime?

  referredBy  String?

  acceptedTerms Boolean @default(false)
  acceptedAt     DateTime?

  lastLoginAt  DateTime?
  lastActiveAt DateTime?

  timezone     String? @default("UTC")

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  paymentLinks  PaymentLink[]
  invoices      Invoice[]
  subscriptions Subscription[]
}



model ReminderSchedule {
  id          String   @id @default(cuid())

  userId      String
  invoiceId   String
  templateId  String

  type        String

  step        Int
  amount      Float
  mode        String

  sendAt      DateTime

  status      String   @default("pending")

  createdAt   DateTime @default(now())

  invoice      Invoice          @relation(fields: [invoiceId], references: [id])

  template     ReminderTemplate @relation(fields: [templateId], references: [id])

  
}