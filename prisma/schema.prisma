// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?

  password  String?   // for admin / optional login
  role      String    @default("USER") // USER / ADMIN
  referredBy String?
  otp       String?
  otpExpiry DateTime?
  isVerified Boolean  @default(false) // ✅ NEW
  createdAt DateTime @default(now())

  subscriptions Subscription[]
  invoices      Invoice[]
}

model Product {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  price     Float
  invoiceLimit Int?  // null = unlimited
  createdAt DateTime @default(now())

  subscriptions Subscription[]
  invoices      Invoice[]
}

model Subscription {
  id                    String   @id @default(uuid())
  userId                String
  productId             String
  paypalSubscriptionId  String?
  status                String   // active, cancelled

  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])
}

model Invoice {
  id          String   @id @default(uuid())
  userId      String
  productId   String
  clientEmail String
  clientName  String?
  amount      Float
  dueDate     DateTime
  status      String   // unpaid, paid
  paymentLink String?

  paidAt      DateTime?   // ✅ ADD THIS  
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])
  reminders Reminder[]
}

model Reminder {
  id         String   @id @default(uuid())
  invoiceId  String
  type       String   // day1, day3, day7
  sentAt     DateTime?
  status     String   // pending, sent

  invoice Invoice @relation(fields: [invoiceId], references: [id])
}

model Payment {
  id        String   @id @default(uuid())
  userId    String
  productId String
  amount    Float
  status    String   // success, failed
  createdAt DateTime @default(now())
}


model MagicLink {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}