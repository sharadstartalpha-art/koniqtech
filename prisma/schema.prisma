generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String         @id @default(uuid())
  email         String         @unique
  name          String?
  password      String?
  role          String         @default("USER")
  referredBy    String?
  isVerified    Boolean        @default(false)
  createdAt     DateTime       @default(now())
  verifyExpiry  DateTime?
  verifyToken   String?
  invoices      Invoice[]
  subscriptions Subscription[]
}

model Product {
  id            String         @id @default(uuid())
  name          String
  slug          String         @unique
  price         Float
  invoiceLimit  Int?
  createdAt     DateTime       @default(now())
  invoices      Invoice[]
  subscriptions Subscription[]
}

model Subscription {
  id                   String   @id @default(uuid())
  userId               String
  productId            String
  paypalSubscriptionId String?
  status               String
  createdAt            DateTime @default(now())
  product              Product  @relation(fields: [productId], references: [id])
  user                 User     @relation(fields: [userId], references: [id])
}

model Invoice {
  id          String     @id @default(uuid())
  userId      String
  productId   String
  clientEmail String
  clientName  String?
  amount      Float
  dueDate     DateTime
  status      String
  paymentLink String?
  paidAt      DateTime?
  createdAt   DateTime   @default(now())
  product     Product    @relation(fields: [productId], references: [id])
  user        User       @relation(fields: [userId], references: [id])
  reminders   Reminder[]
}

model Reminder {
  id        String    @id @default(uuid())
  invoiceId String
  type      String
  sentAt    DateTime?
  status    String
  invoice   Invoice   @relation(fields: [invoiceId], references: [id])
}

model Payment {
  id        String   @id @default(uuid())
  userId    String
  productId String
  amount    Float
  status    String
  createdAt DateTime @default(now())
}

model MagicLink {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}
