generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id String @id @default(uuid())

  name String

  slug String @unique

  industry Industry?

  crmType CRMType

  plan String @default("starter")

  logo String?

  website String?

  phone String?

  email String?

  address String?

  city String?

  state String?

  country String?

  postalCode String?

  timezone String? @default("UTC")

  currency String? @default("USD")

  language String? @default("en")

  taxNumber String?

  businessNumber String?

  active Boolean @default(true)

  usersLimit Int @default(5)

  trialEndsAt DateTime?

  subscriptionEndsAt DateTime?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  departments Department[]

  teams Team[]

  roles UserRole[]

  users User[]

  customers Customer[]

  leads Lead[]

  deals Deal[]

  jobs       Job[]
  emailQueue EmailQueue[]

  smsQueue         SmsQueue[]
  activityTimeline ActivityTimeline[]

  quotes Quote[]

  invoices Invoice[]

  pipelines Pipeline[]

  conversations Conversation[]

  events Event[]

  aiLogs  AiLog[]
  apiLogs ApiLog[]

  notifications Notification[]

  automations Automation[]
  apiKeys     ApiKey[]

  integrations SystemIntegration[]

  settings OrganizationSettings?

  subscriptions Subscription?

  teamInvitations TeamInvitation[]

  inventoryItems InventoryItem[]

  fleetVehicles FleetVehicle[]

  payrolls Payroll[]

  crewMembers CrewMember[]

  platformLogs PlatformLog[]

  purchaseOrders PurchaseOrder[]

  vendors Vendor[]

  assets   Asset[]
  webhooks Webhook[]

  userTasks UserTask[]

  userAttendances UserAttendance[]

  userTimesheets UserTimesheet[]

  userSchedules UserSchedule[]

  userLeaves UserLeave[]

  userExpenses UserExpense[]

  userPayrolls UserPayroll[]

  userPerformance UserPerformance[]

  userDocuments UserDocument[]

  userSignatures UserSignature[]

  userAssetAssignments UserAssetAssignment[]

  userAnnouncements UserAnnouncement[]

  userNotifications UserNotification[]

  knowledgeCategories KnowledgeCategory[]

  knowledgeArticles KnowledgeArticle[]

  userTrainings UserTraining[]

  userNotes UserNote[]

  userReminders UserReminder[]

  userGoals UserGoal[]

  userCommissions UserCommission[]

  userApiKeys UserApiKey[]

  userWebhooks UserWebhook[]

  userEmailQueue UserEmailQueue[]

  userSmsQueue UserSmsQueue[]

  userActivityTimeline UserActivityTimeline[]

  userChatChannels UserChatChannel[]

  userMeetings UserMeeting[]

  userChecklists UserChecklist[]

  userComments UserComment[]

  userRoutes UserRoute[]

  userInspections UserInspection[]

  userWorkOrders UserWorkOrder[]

  userJobPhotos UserJobPhoto[]

  userJobSignatures UserJobSignature[]

  userDailyReports UserDailyReport[]

  userAssets UserAsset[]

  userAssetCategories UserAssetCategory[]

  userAssetMaintenance UserAssetMaintenance[]

  userEquipment UserEquipment[]

  userEquipmentServices UserEquipmentService[]

  userWarranties UserWarranty[]

  userToolCheckouts        UserToolCheckout[]
  userMaintenanceReminders UserMaintenanceReminder[]
  vendorPayments           VendorPayment[]
  warehouses               Warehouse[]

  inventoryTransfers InventoryTransfer[]

  inventoryAdjustments InventoryAdjustment[]

  inventoryCounts InventoryCount[]

  dispatchBoards DispatchBoard[]

  routeOptimizations RouteOptimization[]
  OrganizationRole   OrganizationRole[]
}

model User {
  id String @id @default(uuid())

  orgId String

  name String

  email String @unique

  passwordHash String

  avatar String?

  phone String?

  lastLogin DateTime?

  lastSeen DateTime?

  departmentId String?

  teamId String?

  emailVerified Boolean @default(false)

  phoneVerified Boolean @default(false)

  failedLoginAttempts Int @default(0)

  lockedUntil DateTime?

  status String @default("active")

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  aiLogs AiLog[]

  deals Deal[]

  events Event[]

  jobs Job[]

  technicianLocations TechnicianLocation[]

  payrolls Payroll[]

  assignedLeads Lead[]

  messages Message[]

  sessions Session[]

  notifications Notification[]

  preference UserPreference?

  apiKeys ApiKey[]

  webhooks Webhook[]

  fleetVehicles    FleetVehicle[]
  ActivityTimeline ActivityTimeline[]

  documents UserDocument[]

  uploadedDocuments UserDocument[] @relation("UploadedDocuments")

  signature UserSignature?

  assetAssignments UserAssetAssignment[]

  assignedAssets UserAssetAssignment[] @relation("AssignedAssets")

  assetHistory UserAssetHistory[] @relation("AssetHistoryUser")

  createdAnnouncements UserAnnouncement[] @relation("CreatedAnnouncements")

  announcementReads UserAnnouncementRead[]

  userNotifications UserNotification[]

  leaves UserLeave[] @relation("UserLeaves")

  approvedLeaves UserLeave[] @relation("ApprovedLeaves")

  expenses UserExpense[] @relation("UserExpenses")

  approvedExpenses UserExpense[] @relation("ApprovedExpenses")

  performanceReviews UserPerformance[] @relation("PerformanceEmployee")

  reviewedPerformance UserPerformance[] @relation("PerformanceReviewer")

  department Department? @relation(fields: [departmentId], references: [id])

  team Team? @relation("UserTeam", fields: [teamId], references: [id])

  ledTeams Team[] @relation("TeamLeader")

  permissions UserPermission[]

  reporting UserReporting? @relation("ReportingEmployee")

  managerOf UserReporting[] @relation("ReportingManager")

  sentInvitations TeamInvitation[] @relation("InvitationSender")

  tasksAssigned UserTask[] @relation("AssignedTasks")

  tasksCreated UserTask[] @relation("CreatedTasks")

  attendances UserAttendance[]

  timesheets UserTimesheet[] @relation("UserTimesheets")

  approvedTimesheets UserTimesheet[] @relation("ApprovedTimesheets")

  schedules UserSchedule[]

  knowledgeArticles KnowledgeArticle[] @relation("KnowledgeAuthor")

  createdTrainings UserTraining[] @relation("TrainingCreator")

  trainingProgress TrainingProgress[]

  notes UserNote[] @relation("UserNotes")

  createdNotes UserNote[] @relation("CreatedNotes")

  reminders UserReminder[]

  goals UserGoal[]

  commissions UserCommission[]

  createdApiKeys UserApiKey[] @relation("CreatedApiKeys")

  createdWebhooks UserWebhook[] @relation("CreatedWebhooks")

  emailQueue UserEmailQueue[]

  smsQueue UserSmsQueue[]

  activityTimeline UserActivityTimeline[]

  createdChannels UserChatChannel[] @relation("CreatedChannels")

  chatMemberships UserChatMember[]

  chatMessages UserChatMessage[]

  createdMeetings UserMeeting[] @relation("CreatedMeetings")

  meetingInvites UserMeetingAttendee[]

  assignedChecklists UserChecklist[] @relation("AssignedChecklists")

  createdChecklists UserChecklist[] @relation("CreatedChecklists")

  comments UserComment[]

  createdRoutes UserRoute[] @relation("CreatedRoutes")

  workOrders UserWorkOrder[]

  inspections UserInspection[] @relation()

  uploadedJobPhotos UserJobPhoto[]

  dailyReports UserDailyReport[]

  createdAssetMaintenance UserAssetMaintenance[] @relation("AssetMaintenanceCreator")

  equipmentServices UserEquipmentService[]

  managedWarehouses Warehouse[]

  createdTransfers InventoryTransfer[]

  inventoryAdjustments InventoryAdjustment[]

  inventoryCounts InventoryCount[]

  toolCheckouts    UserToolCheckout[]
  fleetAssignments FleetAssignment[]

  fleetTrips FleetTrip[]

  fuelLogs FleetFuelLog[]

  fleetInspections FleetInspection[]

  dispatchJobs DispatchJob[]

  routeOptimizations RouteOptimization[]

  role               UserRole
  OrganizationRole   OrganizationRole? @relation(fields: [organizationRoleId], references: [id])
  organizationRoleId String?
  UserPayroll        UserPayroll[]
  DispatchBoard      DispatchBoard[]

  @@index([orgId])
  @@index([status])
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Lead {
  id String @id @default(uuid())

  orgId String

  source String?

  firstName String

  lastName String?

  phone String?

  email String?

  companyName String?

  address String?

  budget Float?

  priority String? @default("Medium")

  tags String?

  attachment String?

  industry Industry?

  status LeadStatus @default(new)

  assignedTo String?

  notes LeadNote[]

  createdAt DateTime @default(now())

  customer Customer?

  activities LeadActivity[]

  assignee User? @relation(fields: [assignedTo], references: [id])

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

model Customer {
  id             String          @id @default(uuid())
  orgId          String
  leadId         String?         @unique
  companyName    String?
  firstName      String
  lastName       String?
  email          String?
  phone          String?
  address        String?
  city           String?
  state          String?
  zip            String?
  notes          String?
  createdAt      DateTime        @default(now())
  conversations  Conversation[]
  lead           Lead?           @relation(fields: [leadId], references: [id])
  organization   Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  deals          Deal[]
  hvacUnits      HvacUnit[]
  invoices       Invoice[]
  jobs           Job[]
  plumbingAssets PlumbingAsset[]
  quotes         Quote[]
  UserRouteStop  UserRouteStop[]
  UserEquipment  UserEquipment[]
}

model Pipeline {
  id           String          @id @default(uuid())
  orgId        String
  name         String
  organization Organization    @relation(fields: [orgId], references: [id])
  stages       PipelineStage[]
}

model PipelineStage {
  id         String   @id @default(uuid())
  pipelineId String
  name       String
  position   Int
  deals      Deal[]
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
}

model Deal {
  id            String        @id @default(uuid())
  orgId         String
  customerId    String
  stageId       String
  title         String
  value         Decimal       @db.Decimal(12, 2)
  probability   Int?
  assignedTo    String?
  expectedClose DateTime?
  assignee      User?         @relation(fields: [assignedTo], references: [id])
  customer      Customer      @relation(fields: [customerId], references: [id])
  organization  Organization  @relation(fields: [orgId], references: [id])
  stage         PipelineStage @relation(fields: [stageId], references: [id])
}

model Quote {
  id           String       @id @default(uuid())
  orgId        String
  customerId   String
  quoteNumber  String       @unique
  subtotal     Decimal      @db.Decimal(12, 2)
  tax          Decimal      @db.Decimal(12, 2)
  total        Decimal      @db.Decimal(12, 2)
  status       QuoteStatus  @default(draft)
  validUntil   DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  jobs         Job[]
  customer     Customer     @relation(fields: [customerId], references: [id])
  organization Organization @relation(fields: [orgId], references: [id])
  items        QuoteItem[]
}

model QuoteItem {
  id       String  @id @default(uuid())
  quoteId  String
  itemName String
  qty      Int
  price    Decimal @db.Decimal(12, 2)
  total    Decimal @db.Decimal(12, 2)
  quote    Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
}

model Event {
  id           String       @id @default(uuid())
  orgId        String
  title        String
  startTime    DateTime
  endTime      DateTime
  userId       String?
  jobId        String?
  job          Job?         @relation(fields: [jobId], references: [id])
  organization Organization @relation(fields: [orgId], references: [id])
  user         User?        @relation(fields: [userId], references: [id])
}

model Conversation {
  id           String         @id @default(uuid())
  orgId        String
  customerId   String
  channel      MessageChannel
  createdAt    DateTime       @default(now())
  customer     Customer       @relation(fields: [customerId], references: [id])
  organization Organization   @relation(fields: [orgId], references: [id])
  messages     Message[]
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  senderId       String?
  body           String
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User?        @relation(fields: [senderId], references: [id])
}

model Automation {
  id           String           @id @default(uuid())
  orgId        String
  name         String
  triggerEvent String
  active       Boolean          @default(true)
  organization Organization     @relation(fields: [orgId], references: [id])
  steps        AutomationStep[]
}

model AutomationStep {
  id           String     @id @default(uuid())
  automationId String
  actionType   String
  config       Json
  position     Int
  automation   Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)
}

model AiLog {
  id           String       @id @default(uuid())
  orgId        String
  userId       String
  prompt       String
  response     String
  tokens       Int?
  createdAt    DateTime     @default(now())
  organization Organization @relation(fields: [orgId], references: [id])
  user         User         @relation(fields: [userId], references: [id])
}

model OrganizationSettings {
  id           String       @id @default(uuid())
  orgId        String       @unique
  timezone     String?
  currency     String?
  branding     Json?
  integrations Json?
  organization Organization @relation(fields: [orgId], references: [id])
}

model PlatformLog {
  id           String       @id @default(uuid())
  orgId        String
  eventType    String
  payload      Json
  createdAt    DateTime     @default(now())
  organization Organization @relation(fields: [orgId], references: [id])
}

model RoofingProject {
  id             String   @id @default(uuid())
  jobId          String   @unique
  roofType       String?
  material       String?
  areaSqft       Decimal? @db.Decimal(10, 2)
  insuranceClaim Boolean  @default(false)
  job            Job      @relation(fields: [jobId], references: [id])
}

model HvacUnit {
  id          String    @id @default(uuid())
  customerId  String
  model       String?
  serialNo    String?
  installDate DateTime?
  customer    Customer  @relation(fields: [customerId], references: [id])
}

model PlumbingAsset {
  id          String   @id @default(uuid())
  customerId  String
  fixtureType String?
  location    String?
  customer    Customer @relation(fields: [customerId], references: [id])
}

model LandscapingProject {
  id         String   @id @default(uuid())
  jobId      String   @unique
  yardArea   Decimal? @db.Decimal(10, 2)
  irrigation Boolean  @default(false)
  job        Job      @relation(fields: [jobId], references: [id])
}

model OtpCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())
}

enum Industry {
  roofing
  hvac
  plumbing
  landscaping
}

enum UserRole {
  owner
  admin
  manager
  marketing
  sales
  technician
  support
  accountant
  data_entry
  super_admin
}

enum CRMType {
  roofing
  hvac
  plumbing
  landscaping
  cleaning
}

enum JobStatus {
  scheduled
  in_progress
  completed
  cancelled
}

enum QuoteStatus {
  draft
  sent
  approved
  rejected
  expired
}

enum SubscriptionStatus {
  active
  trial
  cancelled
  expired
}

enum MessageChannel {
  sms
  email
  whatsapp
  internal
}

model ChangeOrder {
  id String @id @default(uuid())

  jobId String

  title String

  amount Float

  status String @default("pending")

  job Job @relation(fields: [jobId], references: [id])
}

model PunchItem {
  id String @id @default(uuid())

  jobId String

  title String

  completed Boolean @default(false)

  job Job @relation(fields: [jobId], references: [id])
}

model JobTask {
  id String @id @default(uuid())

  jobId String

  title String

  status String @default("todo")

  dependsOnId String?
  createdAt   DateTime @default(now())
  job         Job      @relation(fields: [jobId], references: [id])
}

model JobMilestone {
  id String @id @default(uuid())

  jobId String

  title String

  completed Boolean @default(false)

  dueDate   DateTime?
  status    String    @default("pending")
  createdAt DateTime  @default(now())

  job Job @relation(fields: [jobId], references: [id])
}

model MaterialRequest {
  id String @id @default(uuid())

  jobId String

  name String

  quantity Decimal @db.Decimal(10, 2)

  status String @default("requested")

  job Job @relation(fields: [jobId], references: [id])
}

model Job {
  id String @id @default(uuid())

  orgId      String
  customerId String
  quoteId    String?

  title String

  purchaseOrders PurchaseOrder[]
  status         JobStatus       @default(scheduled)

  technicianId String?

  scheduledDate DateTime?

  completedDate DateTime?

  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt

  events Event[]

  customer Customer @relation(fields: [customerId], references: [id])

  organization Organization @relation(fields: [orgId], references: [id])

  quote Quote? @relation(fields: [quoteId], references: [id])

  technician User? @relation(fields: [technicianId], references: [id])

  landscapingProject LandscapingProject?

  roofingProject RoofingProject?

  crewAssignments CrewAssignment[]

  tasks JobTask[]

  milestones JobMilestone[]

  materials MaterialRequest[]

  changeOrders ChangeOrder[]

  punchItems PunchItem[]

  closeout CloseoutPackage?

  routePlans RoutePlan[]
  invoices   Invoice[]

  dispatchJobs DispatchJob[]

  routeStops           RouteStop[]
  UserRouteStop        UserRouteStop[]
  UserInspection       UserInspection[]
  UserWorkOrder        UserWorkOrder[]
  UserJobPhoto         UserJobPhoto[]
  UserJobSignature     UserJobSignature?
  UserEquipment        UserEquipment[]
  UserEquipmentService UserEquipmentService[]
}

model InventoryItem {
  id String @id @default(uuid())

  orgId String
  name  String
  sku   String?
  qty   Int     @default(0)

  unitCost Decimal?

  transactions WarehouseTransaction[]

  purchaseItems PurchaseOrderItem[]

  warehouseStock WarehouseStock[]

  inventoryAdjustments InventoryAdjustment[]

  inventoryCounts InventoryCount[]
  createdAt       DateTime         @default(now())

  organization Organization @relation(fields: [orgId], references: [id])
}

enum FleetStatus {
  active

  maintenance

  inactive

  sold
}

model TechnicianLocation {
  id String @id @default(uuid())

  techId String

  lat Float
  lng Float

  updatedAt DateTime @default(now())

  technician User @relation(fields: [techId], references: [id])
}

model Payroll {
  id String @id @default(uuid())

  orgId  String
  userId String

  hours  Float
  amount Decimal @db.Decimal(12, 2)

  status String

  organization Organization @relation(fields: [orgId], references: [id])

  user User @relation(fields: [userId], references: [id])
}

model WarehouseTransaction {
  id String @id @default(uuid())

  itemId String

  qty  Int
  type String

  createdAt DateTime @default(now())

  item InventoryItem @relation(fields: [itemId], references: [id])
}

model RoutePlan {
  id String @id @default(uuid())

  jobId        String
  technicianId String?

  distance Float?
  duration Float?

  createdAt DateTime @default(now())

  job Job @relation(fields: [jobId], references: [id])
}

model LeadActivity {
  id String @id @default(uuid())

  leadId String

  type  String
  title String

  createdAt DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id])
}

enum LeadStatus {
  new
  contacted
  estimate
  won
  lost
  converted
}

model LeadNote {
  id String @id @default(cuid())

  leadId String

  content String

  createdAt DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model CrewAssignment {
  id String @id @default(uuid())

  jobId String

  crewId String

  assignedAt DateTime @default(now())

  job Job @relation(fields: [jobId], references: [id])

  crew CrewMember @relation(fields: [crewId], references: [id])
}

model CrewMember {
  id String @id @default(uuid())

  orgId String

  name String

  phone String?

  email String?

  role String

  active Boolean @default(true)

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id])

  assignments CrewAssignment[]
}

model CloseoutPackage {
  id String @id @default(uuid())

  jobId String @unique

  notes String?

  finalInspectionPassed Boolean @default(false)

  customerSignOff Boolean @default(false)

  warrantyUploaded Boolean @default(false)

  photosUploaded Boolean @default(false)

  invoicePaid Boolean @default(false)

  completionCertificate Boolean @default(false)

  crewSignOff Boolean @default(false)

  completionDate DateTime?

  completed Boolean @default(false)

  job Job @relation(fields: [jobId], references: [id])
}

model Invoice {
  id String @id @default(uuid())

  orgId      String
  customerId String
  jobId      String

  invoiceNumber String

  subtotal Decimal @db.Decimal(12, 2)
  tax      Decimal @db.Decimal(12, 2)
  total    Decimal @db.Decimal(12, 2)

  dueDate DateTime?
  status  String    @default("draft")

  sentAt DateTime?
  paidAt DateTime?

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id])

  customer Customer @relation(fields: [customerId], references: [id])

  job Job @relation(fields: [jobId], references: [id])
}

model Notification {
  id String @id @default(uuid())

  orgId  String
  userId String?

  title   String
  message String

  type String

  read Boolean @default(false)

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id])

  user User? @relation(fields: [userId], references: [id])
}

model RolePermission {
  id String @id @default(uuid())

  role String

  module String

  canView Boolean @default(false)

  canImport Boolean @default(false)

  canExport Boolean @default(false)

  canApprove Boolean @default(false)

  canAssign Boolean @default(false)

  canCreate Boolean @default(false)

  canEdit Boolean @default(false)

  canDelete Boolean @default(false)

  createdAt          DateTime          @default(now())
  OrganizationRole   OrganizationRole? @relation(fields: [organizationRoleId], references: [id])
  organizationRoleId String?

  @@unique([role, module])
}

model UserPreference {
  id String @id @default(uuid())

  userId String @unique

  timezone   String @default("UTC")
  language   String @default("en")
  dateFormat String @default("MM/DD/YYYY")

  emailNotifications Boolean @default(true)
  smsNotifications   Boolean @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id String @id @default(uuid())

  orgId  String
  userId String

  action   String
  entity   String
  entityId String?

  metadata Json?

  createdAt DateTime @default(now())

  @@index([orgId])
  @@index([userId])
  @@index([createdAt])
}

model Subscription {
  id String @id @default(cuid())

  orgId String @unique

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  provider String

  externalId String? @unique

  customerId String?

  plan String

  status SubscriptionStatus @default(trial)

  billingCycle BillingCycle @default(monthly)

  amount Decimal @db.Decimal(12, 2)

  currency String

  renewAt DateTime?

  nextInvoiceDate DateTime?

  trialStart DateTime?

  trialEnd          DateTime?
  interval          String    @default("month")
  cancelAtPeriodEnd Boolean   @default(false)

  userLimit Int @default(5)

  storageLimit Int @default(20)

  aiCredits Int @default(1000)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}

model Employee {
  id String @id @default(uuid())

  employeeCode String @unique

  firstName String

  lastName String

  email String @unique

  phone String?

  passwordHash String

  departmentId String

  roleId String

  managerId String?

  designation String?

  avatar String?

  joiningDate DateTime?

  dateOfBirth DateTime?

  gender String?

  address String?

  city String?

  state String?

  country String?

  postalCode String?

  emergencyContactName String?

  emergencyContactPhone String?

  bloodGroup String?

  employmentType String?

  salaryType String?

  bankName String?

  accountNumber String?

  ifscCode String?

  upiId String?

  active Boolean @default(true)

  favoriteArticles KnowledgeFavorite[]
  knowledgeViews   KnowledgeView[]

  lastLogin DateTime?

  timeline ActivityTimeline[]

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  department Department @relation(fields: [departmentId], references: [id])

  role EmployeeRole @relation(fields: [roleId], references: [id])

  manager Employee? @relation("ManagerEmployees", fields: [managerId], references: [id])

  subordinates Employee[] @relation("ManagerEmployees")

  assignedCompanies CompanyLead[]

  approvals Approval[]

  tasks EmployeeTask[]

  activities EmployeeActivity[]

  DemoSchedule DemoSchedule[]

  SalesPipeline SalesPipeline[]

  EmployeeSession EmployeeSession[]

  attendances EmployeeAttendance[]

  salaries EmployeeSalary[]

  leaves EmployeeLeave[]

  documents EmployeeDocument[]

  approvedAttendances EmployeeAttendance[] @relation("AttendanceApprover")

