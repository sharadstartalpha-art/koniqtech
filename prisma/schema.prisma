generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id            String                @id @default(uuid())
  name          String
  slug          String                @unique
  industry      Industry?
  plan          String                @default("starter")
  logo          String?
  phone         String?
  email         String?
  active Boolean @default(true)
  address       String?
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
  aiLogs        AiLog[]
  subscriptionEndsAt DateTime?
  trialEndsAt DateTime?
  automations   Automation[]
  conversations Conversation[]
  usersLimit Int @default(5)
  customers     Customer[]
  deals         Deal[]
  events        Event[]
  invoices      Invoice[]
  jobs          Job[]
  crmType CRMType
  leads         Lead[]
  settings      OrganizationSettings?
  pipelines     Pipeline[]
  platformLogs  PlatformLog[]
  quotes        Quote[]
  subscriptions Subscription[]
  users         User[]
}

model User {
  id            String       @id @default(uuid())
  orgId         String
  name          String
  email         String       @unique
  passwordHash  String
  role          UserRole
  avatar        String?
  status        String       @default("active")
  createdAt     DateTime     @default(now())
  aiLogs        AiLog[]
  deals         Deal[]
  events        Event[]
  jobs          Job[]
  assignedLeads Lead[]
  messages      Message[]
  sessions      Session[]
  organization  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Lead {
  id           String       @id @default(uuid())
  orgId        String
  source       String?
  firstName    String
  lastName     String?
  phone        String?
  email        String?
  address      String?
  industry     Industry?
  status       LeadStatus   @default(new)
  assignedTo   String?
  notes        String?
  createdAt    DateTime     @default(now())
  customer     Customer?
  assignee     User?        @relation(fields: [assignedTo], references: [id])
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

model Customer {
  id             String          @id @default(uuid())
  orgId          String
  leadId         String?         @unique
  companyName    String?
  firstName      String
  lastName       String?
  email          String?
  phone          String?
  address        String?
  city           String?
  state          String?
  zip            String?
  notes          String?
  createdAt      DateTime        @default(now())
  conversations  Conversation[]
  lead           Lead?           @relation(fields: [leadId], references: [id])
  organization   Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  deals          Deal[]
  hvacUnits      HvacUnit[]
  invoices       Invoice[]
  jobs           Job[]
  plumbingAssets PlumbingAsset[]
  quotes         Quote[]
}

model Pipeline {
  id           String          @id @default(uuid())
  orgId        String
  name         String
  organization Organization    @relation(fields: [orgId], references: [id])
  stages       PipelineStage[]
}

model PipelineStage {
  id         String   @id @default(uuid())
  pipelineId String
  name       String
  position   Int
  deals      Deal[]
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
}

model Deal {
  id            String        @id @default(uuid())
  orgId         String
  customerId    String
  stageId       String
  title         String
  value         Decimal       @db.Decimal(12, 2)
  probability   Int?
  assignedTo    String?
  expectedClose DateTime?
  assignee      User?         @relation(fields: [assignedTo], references: [id])
  customer      Customer      @relation(fields: [customerId], references: [id])
  organization  Organization  @relation(fields: [orgId], references: [id])
  stage         PipelineStage @relation(fields: [stageId], references: [id])
}

model Quote {
  id           String       @id @default(uuid())
  orgId        String
  customerId   String
  quoteNumber  String       @unique
  subtotal     Decimal      @db.Decimal(12, 2)
  tax          Decimal      @db.Decimal(12, 2)
  total        Decimal      @db.Decimal(12, 2)
  status       QuoteStatus  @default(draft)
  validUntil   DateTime?
  createdAt    DateTime     @default(now())
  jobs         Job[]
  customer     Customer     @relation(fields: [customerId], references: [id])
  organization Organization @relation(fields: [orgId], references: [id])
  items        QuoteItem[]
}

model QuoteItem {
  id       String  @id @default(uuid())
  quoteId  String
  itemName String
  qty      Int
  price    Decimal @db.Decimal(12, 2)
  total    Decimal @db.Decimal(12, 2)
  quote    Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
}

model Job {
  id                 String              @id @default(uuid())
  orgId              String
  customerId         String
  quoteId            String?
  title              String
  status             JobStatus           @default(scheduled)
  technicianId       String?
  scheduledDate      DateTime?
  completedDate      DateTime?
  notes              String?
  events             Event[]
  customer           Customer            @relation(fields: [customerId], references: [id])
  organization       Organization        @relation(fields: [orgId], references: [id])
  quote              Quote?              @relation(fields: [quoteId], references: [id])
  technician         User?               @relation(fields: [technicianId], references: [id])
  landscapingProject LandscapingProject?
  roofingProject     RoofingProject?
}

model Event {
  id           String       @id @default(uuid())
  orgId        String
  title        String
  startTime    DateTime
  endTime      DateTime
  userId       String?
  jobId        String?
  job          Job?         @relation(fields: [jobId], references: [id])
  organization Organization @relation(fields: [orgId], references: [id])
  user         User?        @relation(fields: [userId], references: [id])
}

model Conversation {
  id           String         @id @default(uuid())
  orgId        String
  customerId   String
  channel      MessageChannel
  createdAt    DateTime       @default(now())
  customer     Customer       @relation(fields: [customerId], references: [id])
  organization Organization   @relation(fields: [orgId], references: [id])
  messages     Message[]
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  senderId       String?
  body           String
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User?        @relation(fields: [senderId], references: [id])
}

model Automation {
  id           String           @id @default(uuid())
  orgId        String
  name         String
  triggerEvent String
  active       Boolean          @default(true)
  organization Organization     @relation(fields: [orgId], references: [id])
  steps        AutomationStep[]
}

model AutomationStep {
  id           String     @id @default(uuid())
  automationId String
  actionType   String
  config       Json
  position     Int
  automation   Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)
}

model Subscription {
  id           String             @id @default(uuid())
  orgId        String
  provider     String
  externalId String @unique
  plan         String
  status       SubscriptionStatus
  amount Float @default(199)
  currency String @default("USD")
  interval String @default("month")
  renewAt      DateTime?
  organization Organization       @relation(fields: [orgId], references: [id])
}

model Invoice {
  id           String       @id @default(uuid())
  orgId        String
  customerId   String
  amount       Decimal      @db.Decimal(12, 2)
  status       String
  dueDate      DateTime?
  customer     Customer     @relation(fields: [customerId], references: [id])
  organization Organization @relation(fields: [orgId], references: [id])
}

model AiLog {
  id           String       @id @default(uuid())
  orgId        String
  userId       String
  prompt       String
  response     String
  tokens       Int?
  createdAt    DateTime     @default(now())
  organization Organization @relation(fields: [orgId], references: [id])
  user         User         @relation(fields: [userId], references: [id])
}

model OrganizationSettings {
  id           String       @id @default(uuid())
  orgId        String       @unique
  timezone     String?
  currency     String?
  branding     Json?
  integrations Json?
  organization Organization @relation(fields: [orgId], references: [id])
}

model AdminUser {
  id           String @id @default(uuid())
  email        String @unique
  passwordHash String
  role         String
}

model PlatformLog {
  id           String       @id @default(uuid())
  orgId        String
  eventType    String
  payload      Json
  createdAt    DateTime     @default(now())
  organization Organization @relation(fields: [orgId], references: [id])
}

model RoofingProject {
  id             String   @id @default(uuid())
  jobId          String   @unique
  roofType       String?
  material       String?
  areaSqft       Decimal? @db.Decimal(10, 2)
  insuranceClaim Boolean  @default(false)
  job            Job      @relation(fields: [jobId], references: [id])
}

model HvacUnit {
  id          String    @id @default(uuid())
  customerId  String
  model       String?
  serialNo    String?
  installDate DateTime?
  customer    Customer  @relation(fields: [customerId], references: [id])
}

model PlumbingAsset {
  id          String   @id @default(uuid())
  customerId  String
  fixtureType String?
  location    String?
  customer    Customer @relation(fields: [customerId], references: [id])
}

model LandscapingProject {
  id         String   @id @default(uuid())
  jobId      String   @unique
  yardArea   Decimal? @db.Decimal(10, 2)
  irrigation Boolean  @default(false)
  job        Job      @relation(fields: [jobId], references: [id])
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  orgId     String
  userId    String?
  createdAt DateTime @default(now())
}

enum Industry {
  roofing
  hvac
  plumbing
  landscaping
}

enum UserRole {
  super_admin
  owner
  admin
  manager
  sales
  technician
  support
  accountant
}

enum CRMType {

roofing

hvac

plumbing

landscaping

cleaning

}

enum LeadStatus {
  new
  contacted
  qualified
  proposal
  won
  lost
}

enum JobStatus {
  scheduled
  in_progress
  completed
  cancelled
}

enum QuoteStatus {
  draft
  sent
  approved
  rejected
  expired
}

enum SubscriptionStatus {
  active
  trial
  cancelled
  expired
}

enum MessageChannel {
  sms
  email
  whatsapp
  internal
}
model OtpCode{

id String @id @default(cuid())

email String

code String

expiresAt DateTime

verified Boolean @default(false)

createdAt DateTime @default(now())

}