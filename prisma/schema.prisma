generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Payment {
  id        String   @id @default(uuid())
  userId    String
  productId String
  invoiceId String
  amount    Float
  status    String
  createdAt DateTime @default(now())
  invoice   Invoice  @relation(fields: [invoiceId], references: [id])
}

model MagicLink {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Product {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())

  plans         Plan[]
  invoices      Invoice[]
  subscriptions Subscription[]
}

model Plan {
  id            String         @id @default(uuid())
  productId     String
  name          String // Free / Pro / Business
  price         Float
  invoiceLimit  Int?
  paypalPlanId  String?        @unique
  createdAt     DateTime       @default(now())
  active        Boolean        @default(true)
  product       Product        @relation(fields: [productId], references: [id])
  subscriptions Subscription[]
}

model Subscription {
  id                   String    @id @default(uuid())
  userId               String
  productId            String
  planId               String // 🔥 NEW
  paypalSubscriptionId String?
  status               String
  createdAt            DateTime  @default(now())
  expiresAt            DateTime? // ✅ ADD THIS
  currentPeriodEnd     DateTime? // ✅ ADD THIS
  product              Product   @relation(fields: [productId], references: [id])
  plan                 Plan      @relation(fields: [planId], references: [id])
  user                 User      @relation(fields: [userId], references: [id])
}

model PaymentLink {
  id        String   @id @default(uuid())
  userId    String
  title     String
  url       String? // 👈 TEMP OPTIONAL
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model ReminderTemplate {
  id     String @id @default(cuid())
  userId String

  name    String @unique
  subject String
  html    String // full email HTML

  type      String // 🔥 "friendly" | "firm" | "final" | "custom"
  isDefault Boolean @default(false)

  createdAt         DateTime           @default(now())
  reminderSchedules ReminderSchedule[]
}

model Reminder {
  id String @id @default(uuid())

  userId    String
  invoiceId String

  invoice Invoice @relation(fields: [invoiceId], references: [id])

  type   ReminderType
  status String
  mode   ReminderMode

  channel String @default("email")
  email   String
  amount  Float

  html String
  text String

  templateId String?
  scheduleId String?

  sentAt    DateTime @default(now())
  createdAt DateTime @default(now())

  opens   Int     @default(0)
  clicked Boolean @default(false)
}

model User {
  id String @id @default(uuid())

  email    String  @unique
  password String?

  name           String?
  phone          String?
  whatsappNumber String?
  avatar         String?

  role String @default("USER")

  isVerified Boolean @default(false)

  otp       String?
  otpExpiry DateTime?

  verifyToken  String?
  verifyExpiry DateTime?

  referredBy String?

  acceptedTerms Boolean   @default(false)
  acceptedAt    DateTime?

  lastLoginAt  DateTime?
  lastActiveAt DateTime?

  timezone String? @default("UTC")

  emailProvider String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  businessPhone   String?
  businessEmail   String?
  whatsappEnabled Boolean @default(false)
  smsEnabled      Boolean @default(false)

  paymentLinks  PaymentLink[]
  invoices      Invoice[]
  subscriptions Subscription[]
  campaigns     Campaign[]
 companyName String?
  reminderSchedules ReminderSchedule[]
  reminderLogs      ReminderLog[]
  onboarding        UserOnboarding?
  paymentMethods PaymentMethod[]
}

enum ReminderMode {
  manual
  auto
}

enum ReminderStatus {
  pending
  sent
  failed
}

enum ReminderType {
  friendly
  firm
  final
}

model ReminderSchedule {
  id String @id @default(cuid())

  userId     String
  invoiceId  String
  templateId String?

  amount Float

  type String

  channel String @default("email")
  mode    String @default("auto")

  sendAt DateTime
  step   Int      @default(1)
  status String   @default("pending")

  retryCount Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  template ReminderTemplate? @relation(fields: [templateId], references: [id])
}

model ReminderSettings {
  id String @id @default(uuid())

  userId String @unique

  emailEnabled    Boolean @default(true)
  whatsappEnabled Boolean @default(false)
  smsEnabled      Boolean @default(false)

  autoReminders Boolean @default(true)

  whatsappTemplate String?
  smsTemplate      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Invoice {
  id String @id @default(uuid())

  userId    String
  productId String

  clientEmail    String
  clientName     String?
  clientPhone    String?
  clientWhatsapp String?
  // Financials

  amount Float

  paidAmount Float @default(0)

  balanceAmount Float?

  currency String @default("USD")

  // Status

  status String @default("unpaid")

  mode String @default("manual")

  // Dates

  dueDate DateTime

  paidAt DateTime?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  // Payment

  payments Payment[]

  paymentLink String?

  transactionId String?

  paymentMethod String?

  // Automation

  autoReminder Boolean @default(true)

  // Relations

  product Product @relation(fields: [productId], references: [id])

  user User @relation(fields: [userId], references: [id])

  reminders Reminder[]

  reminderSchedules ReminderSchedule[]

  reminderLogs ReminderLog[]

  autoSendFirstReminder Boolean @default(true)

reminderWorkflow Json?
}

model ReminderLog {
  id String @id @default(cuid())

  userId    String
  invoiceId String

  channel String

  status String

  recipient String

  subject String?
  message String?

  providerMessageId String?

  openedAt  DateTime?
  clickedAt DateTime?

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  invoice Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

model AIRecovery {
  id String @id @default(uuid())

  userId String

  invoiceId String

  score Float

  riskLevel String
  // low | medium | high

  recommendation String

  createdAt DateTime @default(now())
}

model WhatsAppConfig {
  id String @id @default(uuid())

  userId String @unique

  enabled Boolean @default(false)

  phoneNumber String?

  accessToken String?

  businessId String?

  createdAt DateTime @default(now())
}

model SMSConfig {
  id String @id @default(uuid())

  userId String @unique

  enabled Boolean @default(false)

  provider String?
  // twilio | vonage

  accountSid String?

  authToken String?

  fromNumber String?

  createdAt DateTime @default(now())
}

model Campaign {
  id String @id @default(uuid())

  userId String

  name String

  channel String

  message String

  status String @default("pending")

  scheduleDate DateTime?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

model OnboardingProgress {
  id String @id @default(cuid())

  userId String @unique

  connectedEmail Boolean @default(false)

  createdInvoice Boolean @default(false)

  setupWorkflow Boolean @default(false)

  sentReminder Boolean @default(false)

  upgradedPlan Boolean @default(false)

  completed Boolean @default(false)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
}

model UserOnboarding {
  id String @id @default(cuid())

  userId String @unique

  emailConnected Boolean @default(false)

  firstInvoice Boolean @default(false)

  workflowCreated Boolean @default(false)

  firstReminder Boolean @default(false)

  upgraded Boolean @default(false)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}



model PaymentMethod {
  id String @id @default(uuid())

  userId String

  type String
  label String?

  value String

  active Boolean @default(true)

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}