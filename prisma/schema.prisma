generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String  @id @default(uuid())
  email    String  @unique
  name     String?
  password String?
  role     String  @default("USER")

  otp       String?
  otpExpiry DateTime?

  referredBy    String?
  isVerified    Boolean        @default(false)
  createdAt     DateTime       @default(now())
  verifyExpiry  DateTime?
  verifyToken   String?
  paymentLinks  PaymentLink[]
  invoices      Invoice[]
  subscriptions Subscription[]
}

model Invoice {
  id           String     @id @default(uuid())
  userId       String
  productId    String
  clientEmail  String
  clientName   String?
  amount       Float
  mode         String   @default("manual") // 👈 ADD THIS
  dueDate      DateTime
  status       String
  paymentLink  String?
  paidAt       DateTime?
  autoReminder Boolean    @default(true)
  createdAt    DateTime   @default(now())
  product      Product    @relation(fields: [productId], references: [id])
  user         User       @relation(fields: [userId], references: [id])
  reminders    Reminder[]
}

model Payment {
  id        String   @id @default(uuid())
  userId    String
  productId String
  amount    Float
  status    String
  createdAt DateTime @default(now())
}

model MagicLink {
  id        String   @id @default(uuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Product {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())

  plans         Plan[]
  invoices      Invoice[]
  subscriptions Subscription[]
}

model Plan {
  id            String         @id @default(uuid())
  productId     String
  name          String // Free / Pro / Business
  price         Float
  invoiceLimit  Int?
  paypalPlanId  String? // VERY IMPORTANT
  createdAt     DateTime       @default(now())
  active        Boolean        @default(true)
  product       Product        @relation(fields: [productId], references: [id])
  subscriptions Subscription[]
}

model Subscription {
  id                   String    @id @default(uuid())
  userId               String
  productId            String
  planId               String // 🔥 NEW
  paypalSubscriptionId String?
  status               String
  createdAt            DateTime  @default(now())
  expiresAt            DateTime? // ✅ ADD THIS
  currentPeriodEnd DateTime?   // ✅ ADD THIS
  product              Product   @relation(fields: [productId], references: [id])
  plan                 Plan      @relation(fields: [planId], references: [id])
  user                 User      @relation(fields: [userId], references: [id])
}



model PaymentLink {
  id        String   @id @default(uuid())
  userId    String
  title     String
  url       String?   // 👈 TEMP OPTIONAL
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}



enum ReminderMode {
  manual
  auto
}

enum ReminderType {
  friendly
  firm
  final
}


model ReminderTemplate {
  id        String   @id @default(cuid())
  userId    String

  name      String   // "Friendly" | "Firm" | "Final"
  subject   String
  html      String   // full email HTML

  type      String   // 🔥 "friendly" | "firm" | "final" | "custom"
  isDefault Boolean  @default(false)

  schedules ReminderSchedule[]
  createdAt DateTime @default(now())
}

model ReminderSchedule {
  id          String   @id @default(cuid())
  userId      String
  type        ReminderType   // 🔥 ADD THIS
  daysAfter   Int
  templateId  String

  template    ReminderTemplate @relation(fields: [templateId], references: [id])

  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  @@unique([userId, type]) // ✅ THIS FIXES YOUR ERROR
}

model Reminder {
  id        String @id @default(uuid())

  userId    String
  invoiceId String

  invoice   Invoice @relation(fields: [invoiceId], references: [id])

  type   ReminderType
  status String
  mode   ReminderMode

  email  String
  amount Float

  html String
  text String

  templateId String?
  scheduleId String?

  sentAt    DateTime @default(now())
  createdAt DateTime @default(now())

  opens   Int     @default(0)
  clicked Boolean @default(false)
}