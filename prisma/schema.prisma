  transfersTo   InventoryTransfer[] @relation("TransferTo")

  adjustments InventoryAdjustment[]
  counts      InventoryCount[]

  @@index([orgId])
}

model WarehouseStock {
  id String @id @default(uuid())

  warehouseId String

  inventoryItemId String

  quantity Float

  minimumStock Float @default(0)

  maximumStock Float?

  updatedAt DateTime @updatedAt

  warehouse Warehouse @relation(fields: [warehouseId], references: [id], onDelete: Cascade)

  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  @@unique([warehouseId, inventoryItemId])
}

model InventoryTransfer {
  id String @id @default(uuid())

  orgId String

  fromWarehouseId String

  toWarehouseId String

  status String @default("pending")

  transferDate DateTime

  notes String?

  createdById String

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  fromWarehouse Warehouse @relation("TransferFrom", fields: [fromWarehouseId], references: [id])

  toWarehouse Warehouse @relation("TransferTo", fields: [toWarehouseId], references: [id])

  createdBy User @relation(fields: [createdById], references: [id])
}

model InventoryAdjustment {
  id String @id @default(uuid())

  orgId String

  inventoryItemId String

  warehouseId String

  quantity Float

  adjustmentType String

  reason String?

  adjustedById String

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])

  adjustedBy User @relation(fields: [adjustedById], references: [id])
}

model InventoryCount {
  id String @id @default(uuid())

  orgId String

  warehouseId String

  inventoryItemId String

  expectedQty Float

  countedQty Float

  variance Float

  countedById String

  countedAt DateTime

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  warehouse Warehouse @relation(fields: [warehouseId], references: [id])

  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])

  countedBy User @relation(fields: [countedById], references: [id])
}

model FleetVehicle {
  id String @id @default(uuid())

  orgId String

  vehicleNumber String @unique

  name String

  make String?

  model String?

  year Int?

  color String?

  vin String?

  registrationNumber String?

  insuranceNumber String?

  insuranceExpiry DateTime?

  gpsDeviceId String?

  fuelType String?

  odometer Float?

  active Boolean @default(true)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  assignments FleetAssignment[]

  locations FleetLocation[]

  maintenances FleetMaintenance[]

  fuelLogs FleetFuelLog[]

  inspections FleetInspection[]

  trips FleetTrip[]

  driverId String?

  driver User? @relation(fields: [driverId], references: [id])

  DispatchJob DispatchJob[]

  @@index([orgId])
}

model FleetAssignment {
  id String @id @default(uuid())

  vehicleId String

  userId String

  assignedAt DateTime

  returnedAt DateTime?

  notes String?

  active Boolean @default(true)

  vehicle FleetVehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
}

model FleetLocation {
  id String @id @default(uuid())

  vehicleId String

  latitude Float

  longitude Float

  speed Float?

  heading Float?

  accuracy Float?

  recordedAt DateTime

  vehicle FleetVehicle @relation(fields: [vehicleId], references: [id], onDelete: Cascade)

  @@index([recordedAt])
}

model FleetTrip {
  id String @id @default(uuid())

  vehicleId String

  driverId String

  startTime DateTime

  endTime DateTime?

  startLatitude Float?

  startLongitude Float?

  endLatitude Float?

  endLongitude Float?

  startOdometer Float?

  endOdometer Float?

  distance Float?

  duration Int?

  status String @default("running")

  vehicle FleetVehicle @relation(fields: [vehicleId], references: [id])

  driver User @relation(fields: [driverId], references: [id])
}

model FleetMaintenance {
  id String @id @default(uuid())

  vehicleId String

  maintenanceType String

  vendor String?

  cost Float?

  scheduledDate DateTime

  completedDate DateTime?

  nextServiceDate DateTime?

  notes String?

  vehicle FleetVehicle @relation(fields: [vehicleId], references: [id])
}

model FleetFuelLog {
  id String @id @default(uuid())

  vehicleId String

  filledById String

  liters Float

  amount Float

  odometer Float

  fuelStation String?

  receipt String?

  filledAt DateTime

  vehicle FleetVehicle @relation(fields: [vehicleId], references: [id])

  filledBy User @relation(fields: [filledById], references: [id])
}

model FleetInspection {
  id String @id @default(uuid())

  vehicleId String

  inspectedById String

  inspectionDate DateTime

  status String

  notes String?

  vehicle FleetVehicle @relation(fields: [vehicleId], references: [id])

  inspectedBy User @relation(fields: [inspectedById], references: [id])
}

model DispatchBoard {
  id String @id @default(uuid())

  orgId String

  title String

  dispatchDate DateTime

  createdById String

  organization Organization @relation(fields: [orgId], references: [id])

  createdBy User @relation(fields: [createdById], references: [id])

  jobs DispatchJob[]
}

model DispatchJob {
  id String @id @default(uuid())

  dispatchBoardId String

  jobId String

  technicianId String?

  vehicleId String?

  priority String

  estimatedArrival DateTime?

  status String

  dispatchBoard DispatchBoard @relation(fields: [dispatchBoardId], references: [id])

  job Job @relation(fields: [jobId], references: [id])

  technician User? @relation(fields: [technicianId], references: [id])

  vehicle FleetVehicle? @relation(fields: [vehicleId], references: [id])
}

model RouteOptimization {
  id String @id @default(uuid())

  orgId String

  technicianId String

  routeDate DateTime

  totalDistance Float?

  totalDuration Int?

  optimized Boolean @default(false)

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id])

  technician User @relation(fields: [technicianId], references: [id])

  stops RouteStop[]
}

model RouteStop {
  id String @id @default(uuid())

  optimizationId String

  jobId String

  stopOrder Int

  eta DateTime?

  completed Boolean @default(false)

  optimization RouteOptimization @relation(fields: [optimizationId], references: [id], onDelete: Cascade)

  job Job @relation(fields: [jobId], references: [id])
}
