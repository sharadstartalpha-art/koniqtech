generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

//////////////////////////////////////////////////////
// 🔐 AUTH SYSTEM (NextAuth Compatible)
//////////////////////////////////////////////////////

model User {
  id       String  @id @default(cuid())
  name     String?
  email    String  @unique
  password String?
  image    String?

  role Role @default(USER)

  accounts Account[]
  sessions Session[]

  credits      UserCredits?
  transactions Transaction[]

  projects Project[]
  leads    Lead[]

  subscriptions Subscription[] // ✅ ADD THIS

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String // google, github, facebook
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Role {
  USER
  ADMIN
}

//////////////////////////////////////////////////////
// 💰 WALLET / CREDITS SYSTEM
//////////////////////////////////////////////////////

model UserCredits {
  id      String @id @default(cuid())
  userId  String @unique
  balance Int    @default(20) // free credits

  user User @relation(fields: [userId], references: [id])
}

model Transaction {
  id       String          @id @default(cuid())
  userId   String
  amount   Float
  credits  Int
  type     TransactionType
  status   String
  provider String? // paypal, stripe

  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

enum TransactionType {
  CREDIT_PURCHASE
  CREDIT_USAGE
}

//////////////////////////////////////////////////////
// 🧠 MULTI-SAAS PRODUCTS SYSTEM
//////////////////////////////////////////////////////

model Product {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String?
  isActive    Boolean @default(true)

  projects Project[]

  createdAt DateTime @default(now())
}

model Project {
  id        String @id @default(cuid())
  name      String
  userId    String
  productId String

  chats Chat[]
  leads Lead[]

  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])
}

//////////////////////////////////////////////////////
// 🤖 AI CHAT SYSTEM
//////////////////////////////////////////////////////

model Chat {
  id        String @id @default(cuid())
  projectId String

  messages Message[]

  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id])
}

model Message {
  id      String      @id @default(cuid())
  chatId  String
  role    MessageRole
  content String

  createdAt DateTime @default(now())

  chat Chat @relation(fields: [chatId], references: [id])
}

enum MessageRole {
  USER
  ASSISTANT
}

//////////////////////////////////////////////////////
// 🎯 LEAD SYSTEM
//////////////////////////////////////////////////////

model Lead {
  id        String  @id @default(cuid())
  userId    String
  projectId String?

  name     String?
  email    String?
  company  String?
  website  String?
  phone    String?
  location String?

  source String? // google, apollo, hunter
  score  Int? // AI score

  createdAt DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id])
  project Project? @relation(fields: [projectId], references: [id])
}

//////////////////////////////////////////////////////
// 💳 SUBSCRIPTION / PLANS
//////////////////////////////////////////////////////

model Plan {
  id       String  @id @default(cuid())
  name     String
  price    Float
  credits  Int
  isActive Boolean @default(true)

  subscriptions Subscription[] // ✅ ADD THIS

  createdAt DateTime @default(now())
}

model Subscription {
  id        String   @id @default(cuid())
  userId    String
  planId    String

  status    String
  startDate DateTime @default(now())
  endDate   DateTime?

  user User @relation(fields: [userId], references: [id])
  plan Plan @relation(fields: [planId], references: [id])

  @@unique([userId, planId]) // ✅ ADD HERE
}