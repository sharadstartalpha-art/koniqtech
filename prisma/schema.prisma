generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Organization {
  id                 String                @id @default(uuid())
  name               String
  slug               String                @unique
  industry           Industry?
  plan               String                @default("starter")
  logo               String?
  phone              String?
  email              String?
  address            String?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  crmType            CRMType
  active             Boolean               @default(true)
  subscriptionEndsAt DateTime?
  trialEndsAt        DateTime?
  usersLimit         Int                   @default(5)
  aiLogs             AiLog[]
  automations        Automation[]
  conversations      Conversation[]
  customers          Customer[]
  deals              Deal[]
  events             Event[]
  invoices           Invoice[]
  jobs               Job[]
  leads              Lead[]
  settings           OrganizationSettings?
  pipelines          Pipeline[]
  platformLogs       PlatformLog[]
  quotes             Quote[]
  subscriptions      Subscription[]
  users              User[]

  crewMembers    CrewMember[]
  inventoryItems InventoryItem[]
  fleetVehicles  FleetVehicle[]
  payrolls       Payroll[]
}

model User {
  id           String   @id @default(uuid())
  orgId        String
  name         String
  email        String   @unique
  passwordHash String
  role         UserRole
  avatar       String?
  status       String   @default("active")
  createdAt    DateTime @default(now())
  aiLogs       AiLog[]
  deals        Deal[]
  events       Event[]
  jobs         Job[]

  technicianLocations TechnicianLocation[]
  payrolls            Payroll[]

  assignedLeads Lead[]
  messages      Message[]
  sessions      Session[]
  organization  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Lead {
  id           String         @id @default(uuid())
  orgId        String
  source       String?
  firstName    String
  lastName     String?
  phone        String?
  email        String?
  address      String?
  industry     Industry?
  status       LeadStatus     @default(new)
  assignedTo   String?
  notes        LeadNote[]
  createdAt    DateTime       @default(now())
  customer     Customer?
  activities   LeadActivity[]
  assignee     User?          @relation(fields: [assignedTo], references: [id])
  organization Organization   @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

model Customer {
  id             String          @id @default(uuid())
  orgId          String
  leadId         String?         @unique
  companyName    String?
  firstName      String
  lastName       String?
  email          String?
  phone          String?
  address        String?
  city           String?
  state          String?
  zip            String?
  notes          String?
  createdAt      DateTime        @default(now())
  conversations  Conversation[]
  lead           Lead?           @relation(fields: [leadId], references: [id])
  organization   Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  deals          Deal[]
  hvacUnits      HvacUnit[]
  invoices       Invoice[]
  jobs           Job[]
  plumbingAssets PlumbingAsset[]
  quotes         Quote[]
}

model Pipeline {
  id           String          @id @default(uuid())
  orgId        String
  name         String
  organization Organization    @relation(fields: [orgId], references: [id])
  stages       PipelineStage[]
}

model PipelineStage {
  id         String   @id @default(uuid())
  pipelineId String
  name       String
  position   Int
  deals      Deal[]
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
}

model Deal {
  id            String        @id @default(uuid())
  orgId         String
  customerId    String
  stageId       String
  title         String
  value         Decimal       @db.Decimal(12, 2)
  probability   Int?
  assignedTo    String?
  expectedClose DateTime?
  assignee      User?         @relation(fields: [assignedTo], references: [id])
  customer      Customer      @relation(fields: [customerId], references: [id])
  organization  Organization  @relation(fields: [orgId], references: [id])
  stage         PipelineStage @relation(fields: [stageId], references: [id])
}

model Quote {
  id           String       @id @default(uuid())
  orgId        String
  customerId   String
  quoteNumber  String       @unique
  subtotal     Decimal      @db.Decimal(12, 2)
  tax          Decimal      @db.Decimal(12, 2)
  total        Decimal      @db.Decimal(12, 2)
  status       QuoteStatus  @default(draft)
  validUntil   DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  jobs         Job[]
  customer     Customer     @relation(fields: [customerId], references: [id])
  organization Organization @relation(fields: [orgId], references: [id])
  items        QuoteItem[]
}

model QuoteItem {
  id       String  @id @default(uuid())
  quoteId  String
  itemName String
  qty      Int
  price    Decimal @db.Decimal(12, 2)
  total    Decimal @db.Decimal(12, 2)
  quote    Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
}

model Event {
  id           String       @id @default(uuid())
  orgId        String
  title        String
  startTime    DateTime
  endTime      DateTime
  userId       String?
  jobId        String?
  job          Job?         @relation(fields: [jobId], references: [id])
  organization Organization @relation(fields: [orgId], references: [id])
  user         User?        @relation(fields: [userId], references: [id])
}

model Conversation {
  id           String         @id @default(uuid())
  orgId        String
  customerId   String
  channel      MessageChannel
  createdAt    DateTime       @default(now())
  customer     Customer       @relation(fields: [customerId], references: [id])
  organization Organization   @relation(fields: [orgId], references: [id])
  messages     Message[]
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  senderId       String?
  body           String
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User?        @relation(fields: [senderId], references: [id])
}

model Automation {
  id           String           @id @default(uuid())
  orgId        String
  name         String
  triggerEvent String
  active       Boolean          @default(true)
  organization Organization     @relation(fields: [orgId], references: [id])
  steps        AutomationStep[]
}

model AutomationStep {
  id           String     @id @default(uuid())
  automationId String
  actionType   String
  config       Json
  position     Int
  automation   Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)
}

model Subscription {
  id           String             @id @default(uuid())
  orgId        String
  provider     String
  externalId   String             @unique
  plan         String
  status       SubscriptionStatus
  renewAt      DateTime?
  amount       Float              @default(199)
  currency     String             @default("USD")
  interval     String             @default("month")
  organization Organization       @relation(fields: [orgId], references: [id])
}

model AiLog {
  id           String       @id @default(uuid())
  orgId        String
  userId       String
  prompt       String
  response     String
  tokens       Int?
  createdAt    DateTime     @default(now())
  organization Organization @relation(fields: [orgId], references: [id])
  user         User         @relation(fields: [userId], references: [id])
}

model OrganizationSettings {
  id           String       @id @default(uuid())
  orgId        String       @unique
  timezone     String?
  currency     String?
  branding     Json?
  integrations Json?
  organization Organization @relation(fields: [orgId], references: [id])
}

model AdminUser {
  id           String @id @default(uuid())
  email        String @unique
  passwordHash String
  role         String
}

model PlatformLog {
  id           String       @id @default(uuid())
  orgId        String
  eventType    String
  payload      Json
  createdAt    DateTime     @default(now())
  organization Organization @relation(fields: [orgId], references: [id])
}

model RoofingProject {
  id             String   @id @default(uuid())
  jobId          String   @unique
  roofType       String?
  material       String?
  areaSqft       Decimal? @db.Decimal(10, 2)
  insuranceClaim Boolean  @default(false)
  job            Job      @relation(fields: [jobId], references: [id])
}

model HvacUnit {
  id          String    @id @default(uuid())
  customerId  String
  model       String?
  serialNo    String?
  installDate DateTime?
  customer    Customer  @relation(fields: [customerId], references: [id])
}

model PlumbingAsset {
  id          String   @id @default(uuid())
  customerId  String
  fixtureType String?
  location    String?
  customer    Customer @relation(fields: [customerId], references: [id])
}

model LandscapingProject {
  id         String   @id @default(uuid())
  jobId      String   @unique
  yardArea   Decimal? @db.Decimal(10, 2)
  irrigation Boolean  @default(false)
  job        Job      @relation(fields: [jobId], references: [id])
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  orgId     String
  userId    String?
  createdAt DateTime @default(now())
}

model OtpCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())
}

enum Industry {
  roofing
  hvac
  plumbing
  landscaping
}

enum UserRole {
  owner
  admin
  manager
  sales
  technician
  support
  accountant
  super_admin
}

enum CRMType {
  roofing
  hvac
  plumbing
  landscaping
  cleaning
}

enum JobStatus {
  scheduled
  in_progress
  completed
  cancelled
}

enum QuoteStatus {
  draft
  sent
  approved
  rejected
  expired
}

enum SubscriptionStatus {
  active
  trial
  cancelled
  expired
}

enum MessageChannel {
  sms
  email
  whatsapp
  internal
}

model PurchaseOrder {
  id String @id @default(uuid())

  jobId String

  vendor String

  amount Float

  status String @default("draft")

  job Job @relation(fields: [jobId], references: [id])
}

model ChangeOrder {
  id String @id @default(uuid())

  jobId String

  title String

  amount Float

  status String @default("pending")

  job Job @relation(fields: [jobId], references: [id])
}

model PunchItem {
  id String @id @default(uuid())

  jobId String

  title String

  completed Boolean @default(false)

  job Job @relation(fields: [jobId], references: [id])
}

model JobTask {
  id String @id @default(uuid())

  jobId String

  title String

  status String @default("todo")

  dependsOnId String?
  createdAt   DateTime @default(now())
  job         Job      @relation(fields: [jobId], references: [id])
}

model JobMilestone {
  id String @id @default(uuid())

  jobId String

  title String

  completed Boolean @default(false)

  dueDate   DateTime?
  status    String    @default("pending")
  createdAt DateTime  @default(now())

  job Job @relation(fields: [jobId], references: [id])
}

model MaterialRequest {
  id String @id @default(uuid())

  jobId String

  name String

  qty Int

  status String @default("requested")

  job Job @relation(fields: [jobId], references: [id])
}

model Job {
  id String @id @default(uuid())

  orgId      String
  customerId String
  quoteId    String?

  title String

  status JobStatus @default(scheduled)

  technicianId String?

  scheduledDate DateTime?

  completedDate DateTime?

  notes     String?
  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt

  events Event[]

  customer Customer @relation(fields: [customerId], references: [id])

  organization Organization @relation(fields: [orgId], references: [id])

  quote Quote? @relation(fields: [quoteId], references: [id])

  technician User? @relation(fields: [technicianId], references: [id])

  landscapingProject LandscapingProject?

  roofingProject RoofingProject?

  crewAssignments CrewAssignment[]

  tasks JobTask[]

  milestones JobMilestone[]

  materials MaterialRequest[]

  purchaseOrders PurchaseOrder[]

  changeOrders ChangeOrder[]

  punchItems PunchItem[]

  closeout CloseoutPackage?

  routePlans RoutePlan[]
  invoices   Invoice[]
}

model InventoryItem {
  id String @id @default(uuid())

  orgId String
  name  String
  sku   String?
  qty   Int     @default(0)

  unitCost Decimal?

  transactions WarehouseTransaction[]

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id])
}

model FleetVehicle {
  id String @id @default(uuid())

  orgId String
  name  String

  vin   String?
  gpsId String?

  status String

  organization Organization @relation(fields: [orgId], references: [id])
}

model TechnicianLocation {
  id String @id @default(uuid())

  techId String

  lat Float
  lng Float

  updatedAt DateTime @default(now())

  technician User @relation(fields: [techId], references: [id])
}

model Payroll {
  id String @id @default(uuid())

  orgId  String
  userId String

  hours  Float
  amount Decimal

  status String

  organization Organization @relation(fields: [orgId], references: [id])

  user User @relation(fields: [userId], references: [id])
}

model WarehouseTransaction {
  id String @id @default(uuid())

  itemId String

  qty  Int
  type String

  createdAt DateTime @default(now())

  item InventoryItem @relation(fields: [itemId], references: [id])
}

model RoutePlan {
  id String @id @default(uuid())

  jobId        String
  technicianId String?

  distance Float?
  duration Float?

  createdAt DateTime @default(now())

  job Job @relation(fields: [jobId], references: [id])
}

model LeadActivity {
  id String @id @default(uuid())

  leadId String

  type  String
  title String

  createdAt DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id])
}

enum LeadStatus {
  new
  contacted
  estimate
  won
  lost
  converted
}

model LeadNote {
  id String @id @default(cuid())

  leadId String

  content String

  createdAt DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model CrewAssignment {
  id String @id @default(uuid())

  jobId String

  crewId String

  assignedAt DateTime @default(now())

  job Job @relation(fields: [jobId], references: [id])

  crew CrewMember @relation(fields: [crewId], references: [id])
}

model CrewMember {
  id String @id @default(uuid())

  orgId String

  name String

  phone String?

  email String?

  role String

  active Boolean @default(true)

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id])

  assignments CrewAssignment[]
}

model CloseoutPackage {
  id String @id @default(uuid())

  jobId String @unique

  notes String?

  finalInspectionPassed Boolean @default(false)

  customerSignOff Boolean @default(false)

  warrantyUploaded Boolean @default(false)

  photosUploaded Boolean @default(false)

  invoicePaid Boolean @default(false)

  completionCertificate Boolean @default(false)

  crewSignOff Boolean @default(false)

  completionDate DateTime?

  completed Boolean @default(false)

  job Job @relation(fields: [jobId], references: [id])
}

model Invoice {
  id String @id @default(uuid())

  orgId      String
  customerId String
  jobId      String

  invoiceNumber String

  subtotal Float

  tax Float

  total Float

  amount Float

  dueDate DateTime?
  status String @default("draft")

  sentAt DateTime?
  paidAt DateTime?

  createdAt DateTime @default(now())

  organization Organization @relation(fields: [orgId], references: [id])

  customer Customer @relation(fields: [customerId], references: [id])

  job Job @relation(fields: [jobId], references: [id])
}
